{
  "uid": "lovable-build-farm",
  "title": "Build-ферма",
  "tags": ["lovable", "build", "scale", "sprint6"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Build queue depth (lovable_queue_depth{queue=build}) — manual-scale signal",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "lovable_queue_depth{queue=\"build\"}", "legendFormat": "build queue depth" }
      ]
    },
    {
      "id": 2,
      "title": "Worker busy (lovable_worker_busy{queue=build}) — utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "lovable_worker_busy{queue=\"build\"}", "legendFormat": "busy slots" }
      ]
    },
    {
      "id": 3,
      "title": "Build duration p50/p95 (lovable_build_duration_seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le, result) (rate(lovable_build_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{result}}" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, result) (rate(lovable_build_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{result}}" }
      ]
    },
    {
      "id": 4,
      "title": "Re-deploy duration p95 (lovable_redeploy_duration_seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(lovable_redeploy_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{kind}}" }
      ]
    },
    {
      "id": 5,
      "title": "dist artifact source cache-hit vs rebuild (lovable_dist_artifact_source_total)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "sum by (source) (rate(lovable_dist_artifact_source_total[5m]))", "legendFormat": "{{source}}" }
      ]
    },
    {
      "id": 6,
      "title": "GC pending / duration (lovable_project_gc_pending, _duration) — TD-010 gc-lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "lovable_project_gc_pending", "legendFormat": "gc pending" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, result) (rate(lovable_project_gc_duration_seconds_bucket[15m])))", "legendFormat": "gc p95 {{result}}" }
      ]
    }
  ]
}

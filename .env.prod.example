# .env.prod.example — шаблон PROD-переменных Lovable-AI (corelysite.shop).
# Скопируй в .env НА PROD-СЕРВЕРЕ (/opt/corelysite/.env) и заполни РЕАЛЬНЫМИ
# значениями. .env в .gitignore — РЕАЛЬНЫЕ СЕКРЕТЫ НЕ КОММИТИТЬ.
#
# Источник истины:
#   - docs/07-deployment.md → "Канонический список ключей" (имена env символ-в-символ!)
#     + "Prod-модель: shared Traefik" (стр. 231: ENVIRONMENT=prod,
#       APPS_DOMAIN=corelysite.shop, TRAEFIK_NETWORK=web, SITE_ROUTING_MODE=path)
#   - docs/05-security.md → "Секреты" (что секрет, encrypted-at-rest)
#   - docs/adr/ADR-018-prod-deployment-shared-traefik-cicd.md
#
# ВНИМАНИЕ: Settings(extra="ignore") молча игнорирует ОПЕЧАТКИ в именах ->
# поле получит дефолт без ошибки. Имена ключей ниже ОБЯЗАНЫ совпадать с полями
# Settings (config.py) символ-в-символ (docs/07: "символ-в-символ, несовпадение —
# блокер, а не настроится по дефолту").
#
# PROVISION НА PROD: значения секретов на сервере провижатся из GitHub Secrets /
# secret-manager (encrypted-at-rest, docs/05). CI деплоит код; .env с реальными
# значениями кладёт владелец/secret-manager, НЕ репозиторий.
#
# Все значения ниже — ПЛЕЙСХОЛДЕРЫ, НЕ продакшен-секреты.

# ============================================================================
# PROD-ОТЛИЧИЯ от dev (docs/07 стр. 231, ADR-018) — критичные для shared-Traefik
# ============================================================================
# Режим окружения. PROD = prod (is_prod: TLS-verify on, S3 к AWS при пустом
# endpoint, и пр.). Не путать с dev.
ENVIRONMENT=prod
LOG_LEVEL=INFO

# Базовый домен сайтов и API (path-based). PROD = corelysite.shop.
APPS_DOMAIN=corelysite.shop
# PROD: path-based routing (ADR-017) — сайты на {APPS_DOMAIN}/s/{site_id}.
SITE_ROUTING_MODE=path
# PROD: docker-сеть общего edge-Traefik = web (внешняя, external: true).
# worker создаёт сайт-контейнеры в этой сети, общий Traefik их видит.
# ОБЯЗАНО совпадать с networks.web.name в infra/docker-compose.prod.yml.
TRAEFIK_NETWORK=web

# Образ nginx для контейнеров сайтов.
NGINX_IMAGE=nginx:alpine
# Хостовый каталог под dist/ сайтов на prod-сервере.
SITES_HOST_ROOT=/srv/sites
# Эфемерный каталог сборки на build-воркере.
BUILDS_ROOT=/var/builds

# ============================================================================
# Postgres 16 (system of record)
# ============================================================================
POSTGRES_USER=corelysite
# СЕКРЕТ — реальное значение из GitHub Secret POSTGRES_PASSWORD / secret-manager.
POSTGRES_PASSWORD=<prod-postgres-password>
POSTGRES_DB=corelysite

# ============================================================================
# Redis 7 — DSN собирается в compose из имени сервиса redis (REDIS_URL в compose).
# ============================================================================
# REDIS_URL=redis://redis:6379/0   # задаётся в compose, здесь не требуется

# ============================================================================
# S3 / MinIO
# ============================================================================
# Self-hosted MinIO в этом prod-стеке (сервис minio в compose). Compose маппит
# S3_ACCESS_KEY=${MINIO_ROOT_USER}, S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}.
# СЕКРЕТЫ — реальные значения из secret-manager / GitHub Secrets.
MINIO_ROOT_USER=<prod-minio-access-key>
MINIO_ROOT_PASSWORD=<prod-minio-secret-key>
S3_REGION=us-east-1
# ЕДИНЫЙ бакет; разделение артефактов — key-префиксами sources|dist|logs|specs/{job}/.
S3_BUCKET=corelysite-artifacts
#
# ПЕРЕЕЗД НА AWS S3 (docs/02-tech-stack: "в прод — S3 или MinIO-кластер"):
# убрать сервисы minio/minio-setup из compose, очистить S3_ENDPOINT_URL (тогда
# aioboto3 идёт к AWS), задать S3_USE_SSL=true и реальные S3-creds:
# S3_ENDPOINT_URL=
# S3_USE_SSL=true

# ============================================================================
# LLM (Anthropic) — СЕКРЕТ
# ============================================================================
ANTHROPIC_API_KEY=<prod-anthropic-api-key>
# Tiering-модели агентов (дефолты — docs/07 env-контракт; переопредели при нужде):
# AGENT1_MODEL=claude-sonnet-4-6
# AGENT2_MODEL=claude-opus-4-8
# AGENT3_MODEL=claude-opus-4-8
# AGENT4_MODEL=claude-sonnet-4-6

# ============================================================================
# Auth — СЕКРЕТ + конфиг
# ============================================================================
# Seeded opaque Bearer-ключ (legacy fallback на время миграции, ADR-008). СЕКРЕТ.
SEED_API_KEY=<prod-seed-api-key>
# Apple Sign in (Sprint 3): ожидаемый aud identity token = bundle/Services ID.
# Конфиг (не секрет), из Apple Developer.
APPLE_AUDIENCE=mba.gipsy.lovable
# APPLE_JWKS_URL=https://appleid.apple.com/auth/keys

# ============================================================================
# Docker socket / build-воркер (rootless, ADR-010)
# ============================================================================
# GID хостовой группы docker-сокета (чтобы non-root worker читал сокет).
DOCKER_GID=999
# PROD: ROOTLESS Docker-демон (ADR-010, TD-001) — НЕ привилегированный системный
# /var/run/docker.sock. Путь rootless-сокета на prod build-хосте:
ROOTLESS_DOCKER_SOCK=/run/user/1000/docker.sock

# ============================================================================
# Sprint 4: Sandbox & security (ADR-010 rootless+egress, ADR-011 GC)
# ============================================================================
BUILD_SANDBOX_RUNTIME=rootless
# Имя изолированной egress-сети build-контейнера. ОБЯЗАНО совпадать с
# networks.build_egress.name в infra/docker-compose.prod.yml (corelysite_build_egress).
BUILD_EGRESS_NETWORK=corelysite_build_egress
# Хосты npm-registry для egress-proxy (CSV). Синхронно с acl в egress-proxy/squid.conf.
NPM_REGISTRY_ALLOWLIST=registry.npmjs.org
# URL egress-proxy (compose несёт дефолт литералом; раскомментируй для переопределения):
# BUILD_EGRESS_PROXY_URL=http://egress-proxy:3128
# Ресурс-лимиты build-контейнера (compose несёт дефолты; переопредели при нужде):
# BUILD_CPU_LIMIT=2
# BUILD_MEM_LIMIT=2g
# BUILD_PIDS_LIMIT=512
# BUILD_TIMEOUT_S=600
# Кастомный seccomp-профиль: дефолт ПУСТ -> build-код НЕ передаёт --security-opt
# seccomp (встроенный Docker default seccomp активен, провизия не нужна). Непустой
# путь -> devops провижит JSON на build-хосте/в образе worker:
# BUILD_SECCOMP_PROFILE=/etc/corelysite/seccomp/build.json
# GC (ADR-011):
# GC_QUEUE=build
# GC_S3_BATCH_SIZE=1000

# ============================================================================
# Sprint 3.5: Billing / Adapty — СЕКРЕТЫ
# ============================================================================
# Секрет верификации подписи вебхука Adapty (S2S; невалидно -> 401). СЕКРЕТ.
ADAPTY_WEBHOOK_SECRET=<prod-adapty-webhook-secret>
# Secret-ключ Adapty Server-side API (getProfile-ресинк). СЕКРЕТ.
ADAPTY_API_KEY=<prod-adapty-api-key>
# НЕ секреты (compose несёт дефолты; раскомментируй для переопределения):
# ADAPTY_API_BASE=https://api.adapty.io/api/v2
# BILLING_RESYNC_INTERVAL_S=3600
# GRACE_PERIOD_DAYS=7
# SUBSCRIPTION_SWEEP_INTERVAL_S=3600

# ============================================================================
# Sprint 5: Realtime (SSE) & push (APNs) — ADR-012 / ADR-013
# ============================================================================
# SSE (compose несёт дефолты; раскомментируй для переопределения):
# SSE_HEARTBEAT_S=15
# SSE_RETRY_MS=3000
# SSE_MAX_STREAMS_PER_KEY=5
#
# APNs (потребитель: worker). ВНЕШНЯЯ ЗАВИСИМОСТЬ ПОЛЬЗОВАТЕЛЯ (Apple Developer).
# Без credentials notify.apns_push — no-op (push неактивен, пайплайн цел, ADR-013).
# PROD-хост по умолчанию = production (api.push.apple.com).
APNS_ENV=production
# Идентификаторы (конфиг, из Apple Developer):
APNS_KEY_ID=<apple-key-id>
APNS_TEAM_ID=<apple-team-id>
APNS_BUNDLE_ID=mba.gipsy.lovable
#
# СЕКРЕТ (SecretStr) — содержимое .p8 PEM-строкой (для secret-manager без ФС).
# Если задан — приоритетнее APNS_AUTH_KEY_PATH. РЕАЛЬНОЕ значение НЕ КОММИТИТЬ.
# APNS_AUTH_KEY=<.p8 PEM-содержимое или пусто>
#
# Путь к .p8 ВНУТРИ worker-контейнера (если APNS_AUTH_KEY пуст). Файл провижит
# devops/пользователь secret-mount'ом; в git НЕ коммитится (*.p8 в .gitignore).
# APNS_AUTH_KEY_PATH=/secrets/apns/AuthKey.p8
# Хостовый каталог .p8 (монтируется в worker как /secrets/apns ro):
# APNS_AUTH_KEY_HOST_PATH=./secrets/apns
# APNS_JWT_TTL_S=2400

# ============================================================================
# Sprint 6: Observability (ADR-015) + scale (ADR-016)
# ============================================================================
# Sentry DSN — СЕКРЕТ (SecretStr|None). Пусто -> Sentry-init NO-OP. НЕ КОММИТИТЬ.
SENTRY_DSN=<prod-sentry-dsn-or-empty>
# SENTRY_TRACES_SAMPLE_RATE=0.05
# SENTRY_ENVIRONMENT=prod
#
# Prometheus / metrics (compose несёт дефолты; observability-стек в этом
# prod-compose не разворачивается — /metrics экспонируется, scrape опционален):
# METRICS_PORT=9100
# PROMETHEUS_MULTIPROC_DIR=        # масштаб репликами -> multiproc не нужен (пусто)
# PROMETHEUS_SCRAPE_INTERVAL_S=15
#
# Scale (compose несёт дефолты):
# REDIS_POOL_MAX_CONNECTIONS=50
# REDIS_POOL_TIMEOUT_S=5.0
# BILLING_RESYNC_BATCH_SIZE=200

# .env.example — шаблон переменных окружения Lovable-AI (dev).
# Скопируй в .env и заполни. .env в .gitignore — РЕАЛЬНЫЕ СЕКРЕТЫ НЕ КОММИТИТЬ.
# Источник истины: docs/05-security.md (секреты), docs/07-deployment.md.
#
#   cp .env.example .env
#
# Все значения ниже — плейсхолдеры/dev-дефолты, НЕ продакшен-секреты.

# === Postgres 16 (system of record) ===
POSTGRES_USER=lovable
POSTGRES_PASSWORD=<change-me-dev-password>
POSTGRES_DB=lovable

# === Redis 7 (брокер Celery + result backend + pub/sub) ===
# DSN собираются в compose из имени сервиса redis; здесь только для справки.
# REDIS_URL=redis://redis:6379/0

# === MinIO / S3 ===
# Имена ключей канонические (docs/07-deployment.md → "Контракт переменных
# окружения"). Compose маппит S3_ACCESS_KEY=${MINIO_ROOT_USER},
# S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}.
MINIO_ROOT_USER=lovable-minio
MINIO_ROOT_PASSWORD=<change-me-minio-password>
S3_REGION=us-east-1
# ЕДИНЫЙ бакет; разделение артефактов — key-префиксами sources|dist|logs|specs/{job}/
# (НЕ три бакета — app/storage/s3.py использует один s3_bucket).
S3_BUCKET=lovable-artifacts

# === LLM (ADR-032: провайдер выбирается env; дефолт anthropic) ===
# Выбор LLM-провайдера: anthropic (ДЕФОЛТ) / openai. Compose → x-app-env несёт
# дефолт anthropic литералом, поэтому в dev НЕОБЯЗАТЕЛЬНО — раскомментируй только
# для проверки openai-пути (тогда задай OPENAI_API_KEY + GPT-модели AGENTn_MODEL).
# LLM_PROVIDER=anthropic
#
# Anthropic-ключ. Реальный ключ только в .env. Получить — console.anthropic.com.
# При LLM_PROVIDER=openai может быть пустым (не используется).
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# OpenAI-ключ (ADR-032) — нужен ТОЛЬКО при LLM_PROVIDER=openai. При anthropic —
# пусто (compose несёт пустой дефолт). РЕАЛЬНОЕ значение НЕ КОММИТИТЬ.
# OPENAI_API_KEY=<your-openai-api-key>
# reasoning.effort агентов 1/2 при openai (из {medium,high,xhigh}). Дефолт high
# (compose несёт литералом). Агенты 3/4 -> none (не из этого ключа).
# OPENAI_AGENT_EFFORT=high
# Модели агентов при openai (ADR-032 §2, провайдер-специфичные значения тех же
# AGENTn_MODEL; дефолты compose = claude). GPT-IDs верифицированы 2026-06-15:
# AGENT1_MODEL=gpt-5.4-mini
# AGENT2_MODEL=gpt-5.5
# AGENT3_MODEL=gpt-5.4-mini
# AGENT4_MODEL=gpt-5.4-mini
# read/idle- и connect-таймауты LLM-клиента, секунды (ADR-035, float; compose несёт
# дефолты литералом). read = idle между SSE-чанками -> APITimeoutError -> Celery-ретрай.
# LLM_READ_TIMEOUT_S=180.0
# LLM_CONNECT_TIMEOUT_S=10.0

# === Auth (MVP, docs/05-security.md) ===
# Один seeded opaque Bearer-ключ для MVP. В БД хранится только argon2id-хэш.
# Сгенерируй случайную строку, отдай клиенту один раз.
SEED_API_KEY=<generate-random-opaque-key>

# === Деплой сайтов / роутинг ===
# В dev используем *.localhost (резолвится в 127.0.0.1 без правки hosts на
# большинстве систем; для Windows см. infra/README.md → WSL2).
APPS_DOMAIN=apps.localhost
# API_DOMAIN — только для Traefik-лейблов api-сервиса (Host(api.${API_DOMAIN})),
# НЕ поле Settings приложения.
API_DOMAIN=localhost

# Docker-сеть, в которой Traefik видит nginx-контейнеры сайтов.
# КРИТИЧНО: значение должно ТОЧНО совпадать с реальным именем docker-сети, к
# которой подключены и traefik, и сайт-контейнеры (иначе Traefik их не увидит).
# В этом compose сеть имеет фиксированное имя lovable_traefik
# (networks.traefik.name), на него же ссылается traefik.yml
# (providers.docker.network) и лейблы api. Менять — только синхронно во всех трёх.
TRAEFIK_NETWORK=lovable_traefik
# Образ nginx для контейнеров сайтов (docs/02-tech-stack.md).
NGINX_IMAGE=nginx:alpine
# Хостовый каталог, монтируемый в nginx-контейнеры сайтов как dist/.
SITES_HOST_ROOT=/srv/sites
# Эфемерный каталог распаковки/сборки на build-воркере (per-job).
BUILDS_ROOT=/var/builds

# === Docker socket (build-воркер) ===
# GID хостовой группы, владеющей Docker-сокетом, к которому обращается воркер —
# чтобы non-root воркер мог его читать.
# Узнать в WSL2/Linux:  getent group docker | cut -d: -f3
# Типичные значения: 999 (Debian/Ubuntu), 988 (некоторые дистрибутивы).
# Для rootless-демона GID — у служебного пользователя rootless (см. ниже).
DOCKER_GID=999
#
# Sprint 4 (ADR-010, закрывает TD-001): воркер обращается к ROOTLESS Docker-демону,
# а НЕ к привилегированному системному /var/run/docker.sock. Путь rootless-сокета
# на хосте (монтируется в worker как /var/run/docker.sock):
#   - WSL2/Linux rootless:  /run/user/$(id -u)/docker.sock
#     (узнать UID: `id -u`; запустить rootless-демон: `dockerd-rootless-setuptool.sh install`)
# Это снимает корень риска TD-001: компрометация воркера не даёт root на хосте
# (user-namespace remap). Системный /var/run/docker.sock здесь больше НЕ дефолт.
ROOTLESS_DOCKER_SOCK=/run/user/1000/docker.sock

# === Sprint 4: Sandbox & security (ADR-010 rootless+egress, ADR-011 GC) ===
# Канонические имена и дефолты — docs/07-deployment.md → env-контракт (стр. 80-88).
# Имена ДОЛЖНЫ совпадать с полями Settings (config.py) символ-в-символ; поля
# добавляет backend при реализации S4 (до этого Settings(extra=ignore) их глотает).
# НЕ секреты. compose → x-app-env уже несёт дефолты литералами; здесь — для
# переопределения / явности сети+allowlist.
#
# Runtime build-песочницы: rootless (дефолт) / runsc (опц. gVisor поверх).
# BUILD_SANDBOX_RUNTIME=rootless
# Имя изолированной docker-сети build-контейнера. КРИТИЧНО: должно ТОЧНО совпадать
# с реальным именем сети в compose (networks.build_egress.name = lovable_build_egress).
BUILD_EGRESS_NETWORK=lovable_build_egress
# Хосты npm-registry, пропускаемые egress-proxy (CSV). Должен соответствовать
# acl npm_registry dstdomain в infra/egress-proxy/squid.conf (менять синхронно).
NPM_REGISTRY_ALLOWLIST=registry.npmjs.org
# URL egress-proxy в build_egress, через который build-контейнер ходит к npm
# (ADR-010 §C). Воркер инжектит его в build-контейнер как http_proxy/https_proxy.
# Указывает на egress-proxy-сервис (имя:порт = egress-proxy:3128; squid слушает 3128),
# НЕ на app-процессы. НЕ секрет. Compose → x-app-env уже несёт дефолт литералом,
# поэтому здесь НЕОБЯЗАТЕЛЬНО — раскомментируй только для переопределения.
# BUILD_EGRESS_PROXY_URL=http://egress-proxy:3128
# Ресурс-лимиты build-контейнера (resource-exhaustion / anti-fork-bomb).
# BUILD_CPU_LIMIT=2
# BUILD_MEM_LIMIT=2g
# BUILD_PIDS_LIMIT=512
# Wall-clock таймаут сборки, секунды (воркер делает docker rm -f по истечении).
# BUILD_TIMEOUT_S=600
# Путь к кастомному seccomp JSON-профилю build-контейнера (ADR-010 §B-1).
# ДЕФОЛТ ПУСТ -> build-код НЕ передаёт --security-opt seccomp=...; действует
# встроенный default seccomp Docker (syscall-фильтр активен) -> ПРОВИЗИЯ ФАЙЛА
# НЕ НУЖНА (так и оставь пустым в dev). Это НЕ секрет (путь, не credential).
# Docker не имеет токена seccomp=default — допустим только путь к JSON или
# unconfined (unconfined контрактом не предусмотрен). Раскомментируй и задай
# непустой путь ТОЛЬКО для опционального ужесточения; тогда devops ОБЯЗАН
# провизить этот JSON-профиль по указанному пути на build-хосте / в образе worker:
# BUILD_SECCOMP_PROFILE=/etc/lovable/seccomp/build.json
# Celery-очередь джобы project.gc (ADR-011) + размер S3 batch-delete.
# GC_QUEUE=build
# GC_S3_BATCH_SIZE=1000

# === Sprint 4 (deferred): wildcard TLS *.apps.domain (Q-DEPLOY-2) ===
# НЕ активируется в dev (прод-домена нет — dev остаётся APPS_DOMAIN=apps.localhost).
# Заготовка ACME DNS-01 в infra/traefik/dynamic/tls-wildcard.yml (закомментирована).
# При появлении прод-домена: задать APPS_DOMAIN на реальный домен, выбрать
# DNS-провайдера и раскомментировать certresolver + задать token-секрет ниже.
# СЕКРЕТ (НЕ КОММИТИТЬ реальное значение — только в локальном .env прода):
# DNS_PROVIDER_TOKEN=<dns-provider-api-token>
# TLS_ACME_EMAIL=<ops-email-for-acme>
# TLS_DNS_PROVIDER=<lego-dns-provider-code>   # напр. cloudflare / route53 / gcloud

# === Sprint 2: Fixer loop + resilience ===
# Канонические имена и дефолты — docs/07-deployment.md → env-контракт (стр. 46,
# 62-70) + docs/modules/pipeline/03-architecture.md §C (4 гарда) и §E (beat).
# Compose (infra/docker-compose.dev.yml → x-app-env) уже несёт эти дефолты литералами,
# поэтому в .env они НЕОБЯЗАТЕЛЬНЫ — раскомментируй, только если хочешь переопределить.
# НЕ секреты. Имена ДОЛЖНЫ совпадать с полями Settings (config.py) символ-в-символ.
#
# Agent 4 (Fixer) tiering-модель (default Opus: отладка дороже генерации).
# AGENT4_MODEL=claude-opus-4-8
# Гард (a): hard cap попыток fix-loop.
# MAX_FIX_ATTEMPTS=3
# Гард (b): cost cap джобы, USD numeric-строкой.
# JOB_BUDGET_USD=5.0000
# Технический потолок Claude-затрат юзера/мес, USD numeric-строкой.
# USER_MONTHLY_BUDGET_USD=50.0000
# Гард (c): wall-clock cap джобы, секунды (3600 = 1 ч).
# JOB_WALL_CLOCK_BUDGET_S=3600
# Хвост failure_log для Agent 4, байты (32 KiB) — контроль токенов.
# FIXER_LOG_TAIL_BYTES=32768
# TTL AWAITING_CLARIFICATION до FAILED(clarification_timeout), секунды (7 дней).
# CLARIFICATION_TTL_S=604800
# Частота beat-sweeper'а уточнений (§E1), секунды.
# CLARIFICATION_SWEEP_INTERVAL_S=600
# Порог "зависания" в BUILDING/DEPLOYING/FIXING для reconciler'а (§E2), секунды (15 мин).
# STUCK_THRESHOLD_S=900
# Частота beat-reconciler'а застрявших джоб (§E2), секунды.
# RECONCILE_INTERVAL_S=120

# === Sprint 3.5: Billing / Adapty ===
# Канонические имена и дефолты — docs/07-deployment.md → env-контракт (стр. 74-79).
# Имена ДОЛЖНЫ совпадать с полями Settings (config.py) символ-в-символ; поля
# добавляет backend при реализации S3.5 (до этого Settings(extra=ignore) их глотает).
#
# СЕКРЕТЫ (НЕ КОММИТИТЬ реальные значения — только в локальном .env):
# Секрет/ключ верификации подписи вебхука Adapty (POST /v1/billing/webhook/adapty,
# S2S — не Bearer; невалидно -> 401). Потребитель: api. Получить — дашборд Adapty.
ADAPTY_WEBHOOK_SECRET=<generate-random-secret>
# Secret-ключ Adapty Server-side API (getProfile-ресинк). Потребитель: api+worker.
ADAPTY_API_KEY=<adapty-secret-api-key>
#
# НЕ секреты (compose → x-app-env уже несёт дефолты литералами, поэтому здесь
# НЕОБЯЗАТЕЛЬНЫ — раскомментируй только для переопределения):
# Базовый URL Adapty Server-side API v2.
# ADAPTY_API_BASE=https://api.adapty.io/api/v2
# Интервал beat-ресинка getProfile + TTL свежести subscriptions.synced_at, секунды (3600 = 1 ч).
# BILLING_RESYNC_INTERVAL_S=3600
# Длительность grace-периода сайтов при expire/refund (grace_until = expire + это), дни. Продуктово = 7.
# GRACE_PERIOD_DAYS=7
# Частота beat-sweeper'а grace-teardown сайтов (billing.subscription_sweep), секунды (3600 = 1 ч).
# SUBSCRIPTION_SWEEP_INTERVAL_S=3600

# === Sprint 5: Realtime (SSE) & push (APNs) — ADR-012 / ADR-013 ===
# Канонические имена и дефолты — docs/07-deployment.md → env-контракт (стр. 91-100).
# Имена ДОЛЖНЫ совпадать с полями Settings (config.py) символ-в-символ; поля
# добавляет backend при реализации S5 (до этого Settings(extra=ignore) их глотает).
#
# --- SSE (потребитель: api, ADR-012). НЕ секреты. Compose → x-app-env уже несёт
# дефолты литералами, поэтому здесь НЕОБЯЗАТЕЛЬНЫ — раскомментируй для переопределения. ---
# Интервал SSE-heartbeat (": ping") на GET /jobs/{jid}/events, секунды.
# SSE_HEARTBEAT_S=15
# Значение retry: в SSE-потоке (hint клиенту по reconnect), миллисекунды.
# SSE_RETRY_MS=3000
# Макс. одновременных SSE-стримов на ключ (сверх -> 429).
# SSE_MAX_STREAMS_PER_KEY=5
#
# --- APNs push (потребитель: worker, ADR-013). ВНЕШНЯЯ ЗАВИСИМОСТЬ ПОЛЬЗОВАТЕЛЯ
# (Apple Developer). Без credentials notify.apns_push — no-op (push неактивен,
# пайплайн цел; ADR-013 §5). В dev можно оставить всё пустым/закомментированным. ---
# Дефолтный APNs-хост: sandbox (api.sandbox.push.apple.com) / production
# (api.push.apple.com). Compose-дефолт = sandbox.
# APNS_ENV=sandbox
# Apple Key ID .p8-ключа (claim kid). Внешняя зависимость — из Apple Developer (Keys).
# Это идентификатор, не секрет, но конфигурируется пользователем -> плейсхолдер.
APNS_KEY_ID=<apple-key-id>
# Apple Team ID (claim iss). Внешняя зависимость — из Apple Developer (Membership).
APNS_TEAM_ID=<apple-team-id>
# Bundle ID iOS-приложения (заголовок apns-topic). Compose-дефолт = mba.gipsy.lovable.
# APNS_BUNDLE_ID=mba.gipsy.lovable
#
# СЕКРЕТ (SecretStr) — содержимое .p8-ключа PEM-строкой, для secret-manager без ФС.
# Если задан — приоритетнее APNS_AUTH_KEY_PATH (docs/07 стр. 98/109). РЕАЛЬНОЕ
# значение НЕ КОММИТИТЬ — только в локальном .env / secret-manager. В dev обычно
# пусто (тогда backend читает .p8-файл по APNS_AUTH_KEY_PATH; нет и файла -> no-op).
# APNS_AUTH_KEY=<.p8 PEM-содержимое или пусто>
#
# Путь к .p8-файлу ВНУТРИ worker-контейнера (если не задан APNS_AUTH_KEY).
# Compose-дефолт = /secrets/apns/AuthKey.p8 (совпадает с точкой secret-mount'а).
# .p8 — СЕКРЕТНЫЙ КОНФИГ-АРТЕФАКТ: файл провижит ПОЛЬЗОВАТЕЛЬ (Apple Developer
# AuthKey.p8), в git НЕ коммитится (*.p8 в .gitignore). Положи файл в хостовый
# каталог APNS_AUTH_KEY_HOST_PATH (см. ниже) — он смонтируется в /secrets/apns (ro).
# APNS_AUTH_KEY_PATH=/secrets/apns/AuthKey.p8
#
# Хостовый каталог, монтируемый в worker как /secrets/apns (ro). Дефолт —
# ./secrets/apns (infra/secrets/apns, .gitkeep сохраняет пустой каталог; *.p8
# gitignored). Сюда пользователь кладёт AuthKey.p8. Меняй, если ключ лежит вне репо.
# APNS_AUTH_KEY_HOST_PATH=./secrets/apns
#
# TTL кэша provider-JWT (переподпись не чаще; Apple отвергает частую регенерацию), секунды.
# APNS_JWT_TTL_S=2400

# === Sprint 6: Observability (ADR-015) + scale (ADR-016) ===
# Канонические имена и дефолты — docs/07-deployment.md → env-контракт (стр. 103-111).
# Имена ДОЛЖНЫ совпадать с полями Settings (config.py) символ-в-символ; поля
# добавляет backend при реализации S6 (до этого Settings(extra=ignore) их глотает).
# Compose (infra/docker-compose.dev.yml → x-app-env) уже несёт дефолты литералами/
# через :- , поэтому НЕ-секреты здесь НЕОБЯЗАТЕЛЬНЫ — раскомментируй для переопределения.
#
# --- Sentry (потребитель: both, ADR-015 §4). ---
# СЕКРЕТ (SecretStr|None): DSN проекта Sentry. ПУСТО -> Sentry-init NO-OP (фича
# неактивна, процесс цел, как APNs без credentials; docs/07 стр. 103). РЕАЛЬНОЕ
# значение НЕ КОММИТИТЬ — только в локальном .env / secret-manager. В dev обычно пусто.
SENTRY_DSN=<sentry-dsn-or-empty>
# Доля трейсов в Sentry (низкая, чтобы не жечь quota). НЕ секрет.
# SENTRY_TRACES_SAMPLE_RATE=0.05
# environment-тег Sentry (если пусто -> берётся ENVIRONMENT). НЕ секрет.
# SENTRY_ENVIRONMENT=dev
#
# --- Prometheus / metrics (ADR-015 §1). НЕ секреты. ---
# Порт prometheus_client.start_http_server на Celery-воркере/beat (scrape-target
# worker:${METRICS_PORT}/metrics + beat:${METRICS_PORT}/metrics, internal сеть,
# НЕ наружу). Совпадает с expose worker/beat и target в infra/prometheus/prometheus.yml.
# METRICS_PORT=9100
# Каталог multiprocess-режима prometheus-client — ТОЛЬКО если app запускается
# несколькими uvicorn-процессами. В dev/проде масштаб РЕПЛИКАМИ контейнера (один
# процесс на реплику, observability §1) -> multiproc НЕ нужен, оставь ПУСТО.
# PROMETHEUS_MULTIPROC_DIR=
# Интервал scrape (значение для prometheus.yml; в Settings — справочно). ДОЛЖЕН
# совпадать со scrape_interval в infra/prometheus/prometheus.yml.
# PROMETHEUS_SCRAPE_INTERVAL_S=15
#
# --- Grafana admin / Postgres-datasource creds (ADR-015 §5). ---
# СЕКРЕТЫ: admin-пароль Grafana + пароль Postgres-datasource ($/user панель из
# llm_usage). Из env, НЕ хардкод (docs/07 "Правило конфиг-артефакта", docs/05
# Секреты). РЕАЛЬНЫЕ значения НЕ КОММИТИТЬ — только в локальном .env. Postgres-
# datasource creds compose берёт из POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB
# (GF_POSTGRES_DS_*), отдельно задавать не нужно.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<change-me-grafana-admin-password>
#
# --- Scale: Redis ConnectionPool (ADR-016, закрытие TD-007) + resync batch
# (закрытие TD-009). НЕ секреты. ---
# Размер переиспользуемого ConnectionPool на процесс (rate-limit/SSE/budget вместо
# per-request from_url). Следить vs maxclients Redis при росте реплик.
# REDIS_POOL_MAX_CONNECTIONS=50
# Таймаут ожидания свободного соединения из пула, секунды.
# REDIS_POOL_TIMEOUT_S=5.0
# .limit(BATCH) + курсор synced_at ASC в billing.resync (самые протухшие первыми).
# BILLING_RESYNC_BATCH_SIZE=200

# --- Секреты ---
.env
*.env
!.env.example
infra/traefik/acme.json
# Sprint 5 (ADR-013, docs/07 "Правило конфиг-артефакта"): APNs .p8 auth-key —
# секретный конфиг-артефакт от пользователя (Apple Developer). НИКОГДА не
# коммитим .p8; каталог монтируется secret-mount'ом в worker (см.
# infra/docker-compose.dev.yml). Каталог сохраняем через .gitkeep.
infra/secrets/**
!infra/secrets/
!infra/secrets/apns/
!infra/secrets/apns/.gitkeep
*.p8

